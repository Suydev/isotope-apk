# IsotopeAI Self-Hosted — Environment Variables
# Copy this file to .env and fill in the values below.
# Normal users only need SUPABASE_URL and SUPABASE_ANON_KEY.
# Never commit .env to version control.

# ── Required ───────────────────────────────────────────────────────────────
# Your Supabase project URL (from Project Settings → API)
SUPABASE_URL=https://vteqquoqvksshmfhuepu.supabase.co

# Your Supabase anon/public key (from Project Settings → API)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZ0ZXFxdW9xdmtzc2htZmh1ZXB1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODAwODU2NzUsImV4cCI6MjA5NTY2MTY3NX0.ZkRislOhJRQUjVa1y5ixu-xBhlgkXWWyZKI_CClWj64

# ── Optional ───────────────────────────────────────────────────────────────
# Port for the local server (default: 3000)
PORT=3000

# ── Admin / Owner only — leave blank for normal users ─────────────────────
# Set ENABLE_ADMIN_MODE=true to unlock /__admin diagnostics
ENABLE_ADMIN_MODE=false

# Service-role key — owner only, never share, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# Admin unlock secret for /__admin/login
ADMIN_SECRET=

# Supabase account email(s) allowed to use admin unlock
ADMIN_EMAIL=
ADMIN_EMAILS=

# Optional: existing Supabase user email used by /__admin/browser-proof
# Defaults to ADMIN_EMAIL when blank.
BROWSER_PROOF_EMAIL=

# Supabase management API token (owner diagnostics only)
SUPABASE_ACCESS_TOKEN=

# GitHub PAT (owner diagnostics / update checks only)
GITHUB_PAT=

# AI integrations (optional — unlocks AI features in the app)
GEMINI_API_KEY=
GROQ_API_KEY=

# YepAPI key — powers /__ai/* routes (AI chat, YouTube search, web summariser)
# Get a free key with $5 credit at https://yepapi.com
YEPAPI_KEY=

# Session secret (auto-generated if omitted; set manually for persistence)
SESSION_SECRET=
