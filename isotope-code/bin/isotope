#!/usr/bin/env bash
# IsotopeAI CLI
# ──────────────────────────────────────────────────────────────────────────────
# Usage: isotope <command>
#   start              Start the local server in the background
#   stop               Stop the managed local server
#   restart            Stop, start, and open the local app
#   update             Safely pull the latest GitHub version
#   status             Show project path, port, version, and config
#   doctor             Full diagnostic check
#   open               Open http://127.0.0.1:<PORT> in browser
#   logs               Show last 80 server log lines
#   version            Print the installed version
#   repair             Re-run dependency install + CLI reinstall
#   reinstall-widgets  Refresh Termux Widget shortcuts (Termux only)
#   setup              Run setup.sh --no-start from the project dir
# ──────────────────────────────────────────────────────────────────────────────
set -u

ISO_HOME="${ISOTOPE_HOME:-$HOME/.isotope}"
PROJECT_PATH_FILE="$ISO_HOME/project-path"
PID_FILE="$ISO_HOME/isotope.pid"
PORT_FILE="$ISO_HOME/port"
LOG_DIR="$ISO_HOME/logs"
SERVER_LOG="$LOG_DIR/server.log"
UPDATE_LOG="$LOG_DIR/update.log"
DEFAULT_PORT=3000

info() { printf '%s\n' "$*"; }
warn() { printf 'WARN: %s\n' "$*" >&2; }
fail() { printf 'ERROR: %s\n' "$*" >&2; exit 1; }
has()  { command -v "$1" >/dev/null 2>&1; }

redact() {
  sed -E \
    -e 's/(SUPABASE_[A-Z_]*(KEY|TOKEN)|ADMIN_SECRET|GITHUB_PAT|GEMINI_API_KEY|GROQ_API_KEY)=([^[:space:]]+)/\1=[redacted]/g' \
    -e 's/eyJ[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+/[redacted-jwt]/g' \
    -e 's/sbp_[A-Za-z0-9_-]+/[redacted-token]/g' \
    -e 's/gh[pousr]_[A-Za-z0-9_]+/[redacted-token]/g'
}

is_termux() {
  [ -n "${TERMUX_VERSION:-}" ] || printf '%s' "${PREFIX:-}" | grep -q 'com.termux'
}

ensure_home() {
  mkdir -p "$ISO_HOME" "$LOG_DIR"
}

save_project_path() {
  ensure_home
  printf '%s\n' "$1" > "$PROJECT_PATH_FILE"
}

looks_like_project() {
  [ -d "$1" ] && [ -f "$1/server.mjs" ] && [ -f "$1/package.json" ]
}

resolve_project() {
  if [ -n "${ISOTOPE_PROJECT_DIR:-}" ] && looks_like_project "$ISOTOPE_PROJECT_DIR"; then
    printf '%s\n' "$ISOTOPE_PROJECT_DIR"
    return 0
  fi
  if [ -f "$PROJECT_PATH_FILE" ]; then
    p="$(sed -n '1p' "$PROJECT_PATH_FILE")"
    if looks_like_project "$p"; then printf '%s\n' "$p"; return 0; fi
  fi
  p="$(pwd)"
  while [ "$p" != "/" ]; do
    if looks_like_project "$p"; then save_project_path "$p"; printf '%s\n' "$p"; return 0; fi
    p="$(dirname "$p")"
  done
  for try_dir in "$HOME/isotope-code" "$HOME/isotope"; do
    if looks_like_project "$try_dir"; then save_project_path "$try_dir"; printf '%s\n' "$try_dir"; return 0; fi
  done
  fail "Could not find IsotopeAI project. Run setup.sh from the project folder."
}

read_env_key() {
  file="$1"
  key="$2"
  [ -f "$file" ] || return 0
  awk -F= -v k="$key" '
    /^[[:space:]]*#/ || /^[[:space:]]*$/ { next }
    {
      left=$1; gsub(/^[[:space:]]+|[[:space:]]+$/, "", left)
      if (left == k) {
        val=substr($0, index($0,"=")+1)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
        gsub(/^["'"'"']|["'"'"']$/, "", val)
        print val
      }
    }
  ' "$file" | tail -n 1
}

load_env() {
  env_file="$1/.env"
  if [ -f "$env_file" ]; then
    set -a
    # shellcheck disable=SC1090
    . "$env_file"
    set +a
  fi
  PORT="${PORT:-$DEFAULT_PORT}"
  export PORT
}

project_port() {
  project="$1"
  env_port="$(read_env_key "$project/.env" PORT)"
  if [ -n "$env_port" ]; then printf '%s\n' "$env_port"; return; fi
  if [ -f "$PORT_FILE" ]; then sed -n '1p' "$PORT_FILE"; return; fi
  printf '%s\n' "$DEFAULT_PORT"
}

is_running() {
  [ -f "$PID_FILE" ] || return 1
  pid="$(sed -n '1p' "$PID_FILE")"
  [ -n "$pid" ] || return 1
  kill -0 "$pid" >/dev/null 2>&1
}

server_pid() {
  [ -f "$PID_FILE" ] && sed -n '1p' "$PID_FILE" || true
}

health_check() {
  url="$1"
  node - "$url" <<'NODE' >/dev/null 2>&1
const http = require('http');
const url = process.argv[2];
const req = http.get(url, (res) => {
  process.exit(res.statusCode >= 200 && res.statusCode < 500 ? 0 : 1);
});
req.setTimeout(900, () => { req.destroy(); process.exit(1); });
req.on('error', () => process.exit(1));
NODE
}

wait_for_health() {
  port="$1"
  url="http://127.0.0.1:$port/api/version"
  i=0
  while [ "$i" -lt 30 ]; do
    if health_check "$url"; then return 0; fi
    i=$((i + 1))
    sleep 0.5
  done
  return 1
}

open_url() {
  port="${1:-$DEFAULT_PORT}"
  url="http://127.0.0.1:$port"
  if has termux-open-url; then termux-open-url "$url" >/dev/null 2>&1 && return 0; fi
  if has am; then am start -a android.intent.action.VIEW -d "$url" >/dev/null 2>&1 && return 0; fi
  if has xdg-open; then xdg-open "$url" >/dev/null 2>&1 && return 0; fi
  if has open; then open "$url" >/dev/null 2>&1 && return 0; fi
  if has cmd.exe; then cmd.exe /c start "$url" >/dev/null 2>&1 && return 0; fi
  info "Open in browser: $url"
}

port_in_use_by_other() {
  port="$1"
  # Return 0 if port is in use by a process that is NOT the managed Isotope pid
  if ! has ss && ! has netstat; then return 1; fi
  if has ss; then
    ss -tlnp 2>/dev/null | grep -q ":$port " || return 1
  elif has netstat; then
    netstat -tlnp 2>/dev/null | grep -q ":$port " || return 1
  fi
  # Port is in use — check if it's our own managed process
  if is_running; then return 1; fi
  return 0
}

report_stale_aliases() {
  found=0
  for file in "$HOME/.bashrc" "$HOME/.zshrc" "$HOME/.profile" "$HOME/.bash_profile"; do
    [ -f "$file" ] || continue
    while IFS= read -r line; do
      case "$line" in
        *"alias isotope="*|*"alias isotopeai="*|*"function isotope"*|*"function isotopeai"*|*"isotope()"*|*"isotopeai()"*)
          case "$line" in
            *"/bin/isotope"*|*"/usr/bin/isotope"*) ;;
            *)
              warn "stale isotope alias/function in $file: $line"
              found=1
              ;;
          esac
          ;;
      esac
    done < "$file"
  done
  return "$found"
}

# ── cmd_start ─────────────────────────────────────────────────────────────────
cmd_start() {
  ensure_home
  project="$(resolve_project)"
  save_project_path "$project"

  if is_running; then
    port="$(project_port "$project")"
    info "IsotopeAI is already running (PID: $(server_pid))."
    info "Local URL: http://127.0.0.1:$port"
    if health_check "http://127.0.0.1:$port/api/version"; then
      open_url "$port" || true
    else
      warn "Process is alive but /api/version is not responding."
      warn "Check logs: isotope logs"
    fi
    return 0
  fi

  has node || fail "Node.js 18+ is required."
  load_env "$project"
  port="${PORT:-$DEFAULT_PORT}"

  # Check if port is already in use by something else
  if port_in_use_by_other "$port"; then
    warn "Port $port is already in use by another process."
    warn "Change the PORT in $project/.env and retry, or stop the other process."
    return 1
  fi

  printf '%s\n' "$port" > "$PORT_FILE"
  info "Starting IsotopeAI from: $project"
  info "Logs: $SERVER_LOG"

  (
    cd "$project" || exit 1
    if command -v setsid >/dev/null 2>&1; then
      setsid node server.mjs </dev/null >> "$SERVER_LOG" 2>&1 &
    else
      nohup node server.mjs </dev/null >> "$SERVER_LOG" 2>&1 &
    fi
    child_pid="$!"
    printf '%s\n' "$child_pid" > "$PID_FILE"
    disown "$child_pid" 2>/dev/null || true
  )

  if wait_for_health "$port"; then
    info "IsotopeAI started. PID: $(server_pid)"
    info "Local URL: http://127.0.0.1:$port"
    open_url "$port" || true
  else
    warn "Server did not respond to health checks in time."
    warn "Check logs: isotope logs"
    info "Local URL: http://127.0.0.1:$port"
    return 1
  fi
}

# ── cmd_stop ──────────────────────────────────────────────────────────────────
cmd_stop() {
  ensure_home
  if ! is_running; then
    [ -f "$PID_FILE" ] && rm -f "$PID_FILE"
    info "IsotopeAI is not running."
    return 0
  fi
  pid="$(server_pid)"
  info "Stopping IsotopeAI (PID $pid)..."
  kill "$pid" >/dev/null 2>&1 || true
  i=0
  while [ "$i" -lt 20 ]; do
    if ! kill -0 "$pid" >/dev/null 2>&1; then
      rm -f "$PID_FILE"
      info "IsotopeAI stopped."
      return 0
    fi
    i=$((i + 1))
    sleep 0.5
  done
  warn "Graceful stop timed out. Forcing kill."
  kill -9 "$pid" >/dev/null 2>&1 || true
  rm -f "$PID_FILE"
  info "IsotopeAI stopped."
}

# ── cmd_restart ───────────────────────────────────────────────────────────────
cmd_restart() {
  cmd_stop
  cmd_start
}

# ── cmd_version ───────────────────────────────────────────────────────────────
cmd_version() {
  project="$(resolve_project 2>/dev/null || true)"
  if [ -n "$project" ] && [ -f "$project/package.json" ]; then
    ver="$(node - "$project" <<'NODE' 2>/dev/null || printf 'unknown'
const fs = require('fs'), path = require('path');
const dir = process.argv[2];
try {
  const v = JSON.parse(fs.readFileSync(path.join(dir,'package.json'),'utf8')).version || 'unknown';
  process.stdout.write(v);
} catch { process.stdout.write('unknown'); }
NODE
)"
    sha=""
    if [ -f "$project/VERSION" ]; then
      sha="$(node - "$project/VERSION" <<'NODE' 2>/dev/null || true
const fs = require('fs');
try {
  const d = JSON.parse(fs.readFileSync(process.argv[2],'utf8'));
  process.stdout.write(' (sha: ' + (d.sha||'').slice(0,8) + ')');
} catch {}
NODE
)"
    fi
    info "IsotopeAI v${ver}${sha}"
  else
    info "IsotopeAI (project not found)"
  fi
}

# ── cmd_status ────────────────────────────────────────────────────────────────
cmd_status() {
  ensure_home
  project="$(resolve_project 2>/dev/null || true)"
  if [ -z "$project" ]; then
    info "Project path: missing"
    return 1
  fi
  port="$(project_port "$project")"
  env_file="$project/.env"
  supa_url="$(read_env_key "$env_file" SUPABASE_URL)"
  anon="$(read_env_key "$env_file" SUPABASE_ANON_KEY)"
  admin_mode="$(read_env_key "$env_file" ENABLE_ADMIN_MODE)"
  info "Project: $project"
  if is_running; then
    info "Server:  running (PID: $(server_pid))"
  else
    info "Server:  not running"
  fi
  info "Port:    $port"
  info "URL:     http://127.0.0.1:$port"
  # version
  ver="$(node - "$project" <<'NODE' 2>/dev/null || printf 'unknown'
const fs=require('fs'),path=require('path'),dir=process.argv[2];
try{process.stdout.write(JSON.parse(fs.readFileSync(path.join(dir,'package.json'),'utf8')).version||'unknown')}catch{process.stdout.write('unknown')}
NODE
)"
  info "Version: $ver"
  info ".env:    $([ -f "$env_file" ] && printf 'present' || printf 'missing')"
  info "Supabase URL: $([ -n "$supa_url" ] && printf 'configured' || printf 'missing')"
  info "Supabase key: $([ -n "$anon" ] && printf 'configured' || printf 'missing')"
  case "$admin_mode" in
    true|TRUE|1|yes|YES) info "Admin mode: enabled" ;;
    *)                   info "Admin mode: disabled" ;;
  esac
  info "Logs: $SERVER_LOG"
}

# ── cmd_doctor ────────────────────────────────────────────────────────────────
cmd_doctor() {
  ensure_home
  project="$(resolve_project 2>/dev/null || true)"
  info "IsotopeAI doctor"
  info "─────────────────────────────────────"

  # Platform
  if is_termux; then
    info "[ok]  Termux detected (v${TERMUX_VERSION:-unknown})"

    # Warn about Play Store Termux
    VER="${TERMUX_VERSION:-0}"
    case "$VER" in
      0.*)
        warn "[warn] Termux v$VER may be the outdated Play Store version."
        warn "       Install from F-Droid: https://f-droid.org/packages/com.termux/"
        ;;
    esac

    # Check termux-api tools
    has termux-api          && info "[ok]  termux-api installed" \
                            || warn "[warn] termux-api not installed — widget features limited. Run: pkg install termux-api"
    has termux-open-url     && info "[ok]  termux-open-url available" \
                            || warn "[warn] termux-open-url not available (needs termux-api)"
    has termux-wake-lock    && info "[ok]  termux-wake-lock available" \
                            || info "[info] termux-wake-lock not available (optional)"

    # Shortcuts
    SDIR="$HOME/.shortcuts"
    if [ -d "$SDIR" ]; then
      info "[ok]  ~/.shortcuts exists"
      for s in isotope-start isotope-update isotope-open isotope-doctor isotope-stop isotope-repair; do
        if [ -x "$SDIR/$s" ]; then
          info "[ok]  shortcut: $s"
        else
          warn "[warn] shortcut missing: $s (run: bash setup-termux-widget.sh)"
        fi
      done
    else
      warn "[warn] ~/.shortcuts not found — run: bash setup-termux-widget.sh"
    fi
  else
    info "[info] Not running in Termux"
  fi

  info ""
  # Tools
  has node  && info "[ok]  node $(node --version)"  || warn "[fail] node not found"
  has npm   && info "[ok]  npm $(npm --version)"    || warn "[warn] npm not found"
  has git   && info "[ok]  git $(git --version | awk '{print $3}')" || warn "[warn] git not found (needed for isotope update)"
  has curl  && info "[ok]  curl available"          || info "[info] curl not found"
  has wget  && info "[ok]  wget available"          || info "[info] wget not found"

  # Global command
  if command -v isotope >/dev/null 2>&1; then
    info "[ok]  isotope in PATH: $(command -v isotope)"
  else
    warn "[warn] isotope not in PATH — run: bash setup.sh"
  fi

  # Stale aliases
  if ! report_stale_aliases 2>/dev/null; then
    info "[ok]  no stale isotope aliases"
  fi

  info ""
  # Project
  if [ -n "$project" ]; then
    info "[ok]  project: $project"
    [ -f "$project/package.json" ] && info "[ok]  package.json"    || warn "[fail] package.json missing"
    [ -f "$project/server.mjs" ]   && info "[ok]  server.mjs"      || warn "[fail] server.mjs missing"
    [ -f "$project/.env" ]         && info "[ok]  .env present"     || warn "[warn] .env missing — run: bash setup.sh"
    [ -f "$project/update.sh" ]    && info "[ok]  update.sh"        || warn "[warn] update.sh missing"
    [ -f "$project/install-termux.sh" ] && info "[ok]  install-termux.sh" || warn "[warn] install-termux.sh missing"

    supa_url="$(read_env_key "$project/.env" SUPABASE_URL)"
    anon="$(read_env_key "$project/.env" SUPABASE_ANON_KEY)"
    [ -n "$supa_url" ] && info "[ok]  Supabase URL configured" || warn "[warn] Supabase URL missing in .env"
    [ -n "$anon" ]     && info "[ok]  Supabase anon key configured" || warn "[warn] Supabase anon key missing in .env"

    (cd "$project" && node --check server.mjs >/dev/null 2>&1) \
      && info "[ok]  server.mjs syntax" \
      || warn "[fail] server.mjs syntax check failed"

    [ -f "$project/public/sw.js" ]              && info "[ok]  PWA service worker"  || warn "[warn] PWA sw.js missing"
    [ -f "$project/public/manifest.webmanifest" ] && info "[ok]  PWA manifest"      || warn "[warn] PWA manifest missing"
  else
    warn "[warn] project path unknown — run: bash setup.sh from the project directory"
  fi

  # Stale PID check
  info ""
  if [ -f "$PID_FILE" ]; then
    pid="$(sed -n '1p' "$PID_FILE")"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      info "[ok]  managed process alive (PID: $pid)"
    elif [ -n "$pid" ]; then
      warn "[warn] stale PID file detected (PID $pid is not running) — will be cleared on next start"
    fi
  fi

  # Server health
  if is_running && [ -n "$project" ]; then
    port="$(project_port "$project")"
    if health_check "http://127.0.0.1:$port/api/version"; then
      info "[ok]  /api/version endpoint responding on port $port"
    else
      warn "[fail] /api/version not responding (server may be starting up)"
    fi
  else
    info "[info] local server not running"
  fi

  info ""
  info "Run 'isotope repair' to fix dependency or command issues."
  info "Run 'isotope logs' to see recent server output."
}

# ── cmd_repair ────────────────────────────────────────────────────────────────
cmd_repair() {
  ensure_home
  project="$(resolve_project)"
  info "IsotopeAI repair"
  info "Project: $project"
  info "This will re-run dependency install and CLI reinstall."
  info "Your .env will not be modified."
  (
    cd "$project" || fail "Cannot cd into $project"
    bash setup.sh --yes --no-start --repair \
      || warn "Repair had errors. Check output above."
  )
  if is_termux && [ -f "$project/setup-termux-widget.sh" ]; then
    info "Refreshing Termux Widget shortcuts..."
    bash "$project/setup-termux-widget.sh" || warn "Widget refresh had errors."
  fi
  # Clear any stale PID
  if [ -f "$PID_FILE" ]; then
    pid="$(sed -n '1p' "$PID_FILE")"
    if [ -n "$pid" ] && ! kill -0 "$pid" 2>/dev/null; then
      info "Clearing stale PID file ($pid)."
      rm -f "$PID_FILE"
    fi
  fi
  info "Repair complete. Run 'isotope doctor' to verify."
}

# ── cmd_reinstall_widgets ─────────────────────────────────────────────────────
cmd_reinstall_widgets() {
  is_termux || fail "reinstall-widgets is only available on Android Termux."
  project="$(resolve_project)"
  [ -f "$project/setup-termux-widget.sh" ] \
    || fail "setup-termux-widget.sh not found in $project"
  info "Reinstalling Termux Widget shortcuts..."
  bash "$project/setup-termux-widget.sh"
}

# ── cmd_setup ─────────────────────────────────────────────────────────────────
cmd_setup() {
  project="$(resolve_project)"
  info "Running setup from: $project"
  (
    cd "$project" || fail "Cannot cd into $project"
    bash setup.sh --no-start
  )
}

# ── cmd_update ────────────────────────────────────────────────────────────────
write_version_file() {
  project="$1"
  (cd "$project" && node - <<'NODE'
const cp = require('child_process');
const fs = require('fs');
const path = require('path');
let sha = 'unknown', message = '', version = '0.0.0';
try { sha = cp.execSync('git rev-parse HEAD').toString().trim(); } catch {}
try { message = cp.execSync('git log -1 --pretty=%s').toString().trim(); } catch {}
try { version = JSON.parse(fs.readFileSync(path.join(process.cwd(),'package.json'),'utf8')).version || version; } catch {}
fs.writeFileSync('VERSION', JSON.stringify({ version, sha, message, updated_at: new Date().toISOString() }, null, 2) + '\n');
NODE
  )
}

cmd_update_body() {
  ensure_home
  project="$(resolve_project)"
  save_project_path "$project"
  has git  || fail "Git is required for isotope update."
  has node || fail "Node.js 18+ is required."
  was_running=0
  is_running && was_running=1
  info "IsotopeAI update"
  info "Project: $project"
  info "Your .env will be preserved."
  cd "$project" || exit 1
  [ -d .git ] || fail "Not a Git checkout. Clone the repo or download the latest release."

  stash_name=""
  if ! git diff --quiet || ! git diff --cached --quiet || [ -n "$(git ls-files --others --exclude-standard)" ]; then
    stash_name="isotope-auto-stash-$(date +%Y%m%d%H%M%S)"
    info "Local changes detected — stashing as: $stash_name"
    git stash push -u -m "$stash_name" >/dev/null || fail "Could not stash local changes."
  fi

  branch="$(git rev-parse --abbrev-ref HEAD)"
  [ "$branch" != "HEAD" ] || fail "Detached HEAD. Checkout a branch before updating."
  info "Fetching origin/$branch..."
  git fetch origin "$branch" || fail "git fetch failed. Check internet connection."
  local_sha="$(git rev-parse HEAD)"
  remote_sha="$(git rev-parse "origin/$branch")"
  if [ "$local_sha" = "$remote_sha" ]; then
    info "Already up to date."
  else
    git merge-base --is-ancestor "$local_sha" "$remote_sha" \
      || fail "Local branch has diverged. Your changes are safe. Update manually with Git."
    package_changed="$(git diff --name-only "$local_sha" "$remote_sha" | grep -E '^(package\.json|package-lock\.json)$' || true)"
    info "Applying fast-forward update..."
    git merge --ff-only "$remote_sha" || fail "Fast-forward merge failed."
    if [ -n "$package_changed" ] && has npm; then
      info "Package files changed — running npm install..."
      npm install || fail "npm install failed."
    fi
  fi

  [ -f .env ] || { [ -f .env.example ] && cp .env.example .env && info "Created .env from .env.example."; }
  node --check server.mjs >/dev/null 2>&1 || fail "server.mjs syntax check failed after update."
  write_version_file "$project"

  # Refresh Termux widgets on update
  if is_termux && [ -f setup-termux-widget.sh ]; then
    info "Refreshing Termux Widget shortcuts..."
    bash setup-termux-widget.sh || warn "Widget refresh had errors."
  fi

  info "Update complete."
  [ -n "$stash_name" ] && info "Stashed local changes saved as: $stash_name"

  if [ "$was_running" -eq 1 ]; then
    info "Restarting server..."
    cmd_stop
    cmd_start
  else
    info "Start with: isotope start"
  fi
}

cmd_update() {
  ensure_home
  : > "$UPDATE_LOG"
  cmd_update_body 2>&1 | redact | tee -a "$UPDATE_LOG"
  status=${PIPESTATUS[0]}
  if [ "$status" -ne 0 ]; then
    warn "Update failed. Log: $UPDATE_LOG"
    return "$status"
  fi
  info "Update log: $UPDATE_LOG"
}

# ── cmd_open ──────────────────────────────────────────────────────────────────
cmd_open() {
  project="$(resolve_project 2>/dev/null || true)"
  if [ -n "$project" ]; then port="$(project_port "$project")"; else port="$DEFAULT_PORT"; fi
  if ! health_check "http://127.0.0.1:$port/api/version"; then
    warn "Server is not responding on port $port."
    warn "Start the server first: isotope start"
    return 1
  fi
  open_url "$port"
}

# ── cmd_logs ──────────────────────────────────────────────────────────────────
cmd_logs() {
  ensure_home
  if [ ! -f "$SERVER_LOG" ]; then
    info "No server log yet: $SERVER_LOG"
    return 0
  fi
  tail -n 80 "$SERVER_LOG" | redact
}

# ── usage ─────────────────────────────────────────────────────────────────────
usage() {
  cat <<'EOF'
Usage: isotope <command>

Commands:
  start               Start the local IsotopeAI server (background)
  stop                Stop the managed local server
  restart             Stop, start, and open the local app
  update              Safely pull the latest GitHub version
  status              Show project path, port, version, and config
  doctor              Full diagnostic — checks all dependencies
  open                Open http://127.0.0.1:<PORT> in browser
  logs                Show last 80 server log lines (secrets redacted)
  version             Print the installed version
  repair              Re-run dependency install and CLI reinstall
  reinstall-widgets   Refresh Termux home-screen shortcuts (Termux only)
  setup               Run setup.sh --no-start from the project directory
  help / --help       Show this message
EOF
}

# ── main dispatch ─────────────────────────────────────────────────────────────
cmd="${1:-}"
case "$cmd" in
  start)               cmd_start ;;
  stop)                cmd_stop ;;
  restart)             cmd_restart ;;
  update)              cmd_update ;;
  status)              cmd_status ;;
  doctor)              cmd_doctor ;;
  open)                cmd_open ;;
  logs)                cmd_logs ;;
  version)             cmd_version ;;
  repair)              cmd_repair ;;
  reinstall-widgets)   cmd_reinstall_widgets ;;
  setup)               cmd_setup ;;
  ""|help|--help|-h)   usage ;;
  *)                   warn "Unknown command: $cmd"; usage; exit 1 ;;
esac
